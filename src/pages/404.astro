---
import Base from "../layouts/Base.astro";
---
<Base title="Page not found \u2014 Harmony Threads" description="We looked, but this page isn't in the crate." noindex={true}>
  <section class="max-w-2xl mx-auto px-5 md:px-8 py-32 text-center">
    <p class="text-xs uppercase tracking-[0.2em] text-amber/90 mb-4">404 \u00b7 Track missing</p>
    <h1 class="font-display text-6xl md:text-7xl">B-side only.</h1>
    <p class="mt-5 text-paper/75 text-lg">We looked in every sleeve \u2014 this page isn't in the crate. Try the shop or the journal instead.</p>
    <div class="mt-8 flex justify-center gap-3">
      <a href="/shop" class="rounded-full bg-amber text-ink font-semibold px-6 py-3 hover:bg-amber-dark">Go to the shop</a>
      <a href="/" class="rounded-full border border-white/20 px-6 py-3 hover:border-amber">Back home</a>
    </div>
  </section>
</Base>
