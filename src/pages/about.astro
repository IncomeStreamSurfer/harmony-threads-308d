---
import Base from "../layouts/Base.astro";

const schema = [
  { "@context": "https://schema.org", "@type": "AboutPage", name: "About Harmony Threads", url: new URL("/about", Astro.site).toString() },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: Astro.site?.toString() },
      { "@type": "ListItem", position: 2, name: "About", item: new URL("/about", Astro.site).toString() },
    ],
  },
];
---
<Base title="About Harmony Threads \u2014 A small-batch record store for the rest of your life" description="How Harmony Threads started in a Manchester basement \u2014 and why every t-shirt, eBook and fragrance is made the slow way." structuredData={schema}>
  <section class="max-w-4xl mx-auto px-5 md:px-8 pt-16 pb-10">
    <nav class="text-xs text-paper/60 mb-6">
      <a href="/" class="hover:text-amber">Home</a>
      <span class="mx-2">/</span>
      <span class="text-paper/80">About</span>
    </nav>
    <p class="text-xs uppercase tracking-[0.2em] text-amber/90 mb-4">Since 2022 \u00b7 Manchester, UK</p>
    <h1 class="font-display text-5xl md:text-6xl leading-tight">A small-batch record store <span class="italic text-amber">for the rest of your life.</span></h1>
    <p class="mt-6 text-lg text-paper/75 leading-relaxed">Harmony Threads started in the basement of a second-hand amp repair shop in the Northern Quarter. We owned one screen-printing rig, two copies of a paperback about The Band, and a single bottle of home-blended fragrance. Four years later we own three of each, and not much more.</p>
  </section>

  <section class="max-w-4xl mx-auto px-5 md:px-8 py-10 grid md:grid-cols-2 gap-8">
    <img src="https://burst.shopifycdn.com/photos/vinyl-records.jpg?width=900" alt="Vinyl records" class="rounded-2xl aspect-[4/5] object-cover" />
    <div class="prose prose-invert">
      <h2 class="font-display text-3xl">Why three products \u2014 and only three?</h2>
      <p class="text-paper/75 leading-relaxed mt-3">We don't believe in storefronts with 400 SKUs and one narrative. We believe in the opposite: three well-chosen items that share a worldview. A t-shirt you'll still wear in a decade. An eBook long enough to live with. A fragrance that smells like the Saturday after a good gig.</p>
      <h2 class="font-display text-3xl mt-8">The slow way</h2>
      <p class="text-paper/75 leading-relaxed mt-3">Every tee is screened in runs of 40 or fewer, by hand, in our Manchester studio. The eBook was written over two years, edited for four months, and narrated by the author in a booth above the Night & Day caf\u00e9. The fragrance is blended in Grasse in 40-bottle batches \u2014 we release one run per quarter.</p>
      <p class="text-paper/75 leading-relaxed mt-3">You can buy everything we make on <a class="text-amber underline" href="/shop">one short page</a>. That's the whole point.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-5 md:px-8 py-16">
    <h2 class="font-display text-3xl mb-8">The house code</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {[
        { h: "Nothing dropshipped", p: "If it isn't made by us or someone we know, it isn't on the shelf." },
        { h: "No reprints", p: "When a colourway sells out, that's the colourway gone. We'll miss it too." },
        { h: "Pay writers", p: "Every Journal piece is commissioned at professional rates. No AI slop." },
        { h: "Ship worldwide", p: "We'll post anywhere, but we'll tell you the real shipping price up front." },
      ].map((c) => (
        <div class="rounded-2xl border border-white/10 bg-black/40 p-6">
          <h3 class="font-display text-xl">{c.h}</h3>
          <p class="mt-2 text-paper/70 text-sm leading-relaxed">{c.p}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-5 md:px-8 py-12 text-center">
    <p class="text-paper/70">Got a question the shop doesn't answer? <a href="/contact" class="text-amber underline">Send us a note \u2192</a></p>
  </section>
</Base>
