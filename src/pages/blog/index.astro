---
import Base from "../../layouts/Base.astro";
import { supabase, type DbContent } from "../../lib/supabase";

export const prerender = false;

let posts: DbContent[] = [];
try {
  const { data } = await supabase
    .from("content")
    .select("*")
    .not("published_at", "is", null)
    .order("published_at", { ascending: false })
    .limit(24);
  if (data) posts = data as DbContent[];
} catch (e) {}

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: "Harmony Threads Journal",
    url: new URL("/blog", Astro.site).toString(),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: Astro.site?.toString() },
      { "@type": "ListItem", position: 2, name: "Journal", item: new URL("/blog", Astro.site).toString() },
    ],
  },
];
---
<Base title="The Journal \u2014 Harmony Threads" description="Long-form writing about rock music, craft, and the slow-made life \u2014 published monthly." structuredData={schema}>
  <section class="max-w-4xl mx-auto px-5 md:px-8 pt-16 pb-10">
    <nav class="text-xs text-paper/60 mb-6">
      <a href="/" class="hover:text-amber">Home</a>
      <span class="mx-2">/</span>
      <span class="text-paper/80">Journal</span>
    </nav>
    <p class="text-xs uppercase tracking-[0.2em] text-amber/90 mb-3">Monthly \u00b7 long-form</p>
    <h1 class="font-display text-5xl md:text-6xl">The Journal</h1>
    <p class="mt-4 max-w-2xl text-paper/75 text-lg">Long-form writing about the music we love, the craft behind what we make, and the people who still believe a good record can change a week.</p>
  </section>

  {posts.length > 0 ? (
    <section class="max-w-4xl mx-auto px-5 md:px-8 pb-20 space-y-8">
      {posts.map((p) => (
        <a href={`/blog/${p.slug}`} class="group block rounded-2xl border border-white/10 bg-black/40 p-6 md:p-8 hover:border-amber/40 transition">
          <p class="text-xs text-paper/50">{p.published_at ? new Date(p.published_at).toLocaleDateString("en-GB",{ day: "numeric", month: "long", year: "numeric" }) : ""}</p>
          <h2 class="font-display text-2xl md:text-3xl mt-1 group-hover:text-amber">{p.title}</h2>
          {p.excerpt && <p class="mt-3 text-paper/75 line-clamp-3">{p.excerpt}</p>}
          <p class="mt-4 text-amber text-sm">Read the piece \u2192</p>
        </a>
      ))}
    </section>
  ) : (
    <section class="max-w-3xl mx-auto px-5 md:px-8 pb-24">
      <div class="rounded-3xl border border-amber/30 bg-gradient-to-br from-black to-ink p-10 md:p-14 text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-amber/90 mb-3">Coming soon</p>
        <h2 class="font-display text-3xl">Fresh writing on the way.</h2>
        <p class="mt-3 text-paper/70 max-w-xl mx-auto">The first piece lands later this season. Join the newsletter and you'll be the first to read it \u2014 no hype, one email a month, unsubscribe any time.</p>
        <form action="/api/subscribe" method="post" class="mt-6 flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input type="email" name="email" required placeholder="you@loudworld.com" class="flex-1 bg-black border border-white/15 rounded-lg px-4 py-3 placeholder:text-paper/40 focus:outline-none focus:border-amber" />
          <button class="rounded-lg bg-amber text-ink font-semibold px-6 py-3 hover:bg-amber-dark">Subscribe</button>
        </form>
      </div>
    </section>
  )}
</Base>
