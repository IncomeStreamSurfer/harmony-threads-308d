---
import Base from "../../layouts/Base.astro";
import ProductCard from "../../components/ProductCard.astro";
import { collections, productsByCollection, products } from "../../data/products";

export function getStaticPaths() {
  return collections.map((c) => ({ params: { slug: c.slug } }));
}
export const prerender = true;

const { slug } = Astro.params;
const collection = collections.find((c) => c.slug === slug);
if (!collection) return Astro.redirect("/shop", 302);
const items = productsByCollection(collection.slug);

const hero: Record<string, { img: string; title: string; blurb: string }> = {
  apparel:   { img: "https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=1600", title: "Apparel", blurb: "Hand-screened rock graphic tees in small runs. 180gsm heavyweight cotton. Unisex fit. Three colourways, four sizes." },
  digital:   { img: "https://burst.shopifycdn.com/photos/vinyl-records.jpg?width=1600", title: "Digital", blurb: "Long-form rock writing, delivered to your inbox. PDF, Kindle, and audiobook." },
  fragrance: { img: "https://burst.shopifycdn.com/photos/black-glass-perfume-bottle-and-spritzer.jpg?width=1600", title: "Fragrance", blurb: "A signature scent for long nights. Amber, smoked cedar, vintage leather." },
};
const h = hero[collection.slug];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: `${collection.title} \u00b7 Harmony Threads`,
    description: collection.description,
    url: new URL(`/collections/${collection.slug}`, Astro.site).toString(),
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: items.map((p, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: new URL(`/product/${p.handle}`, Astro.site).toString(),
      name: p.title,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: Astro.site?.toString() },
      { "@type": "ListItem", position: 2, name: "Shop", item: new URL("/shop", Astro.site).toString() },
      { "@type": "ListItem", position: 3, name: collection.title, item: new URL(`/collections/${collection.slug}`, Astro.site).toString() },
    ],
  },
];
---
<Base
  title={`${collection.title} \u00b7 Harmony Threads`}
  description={collection.description}
  ogImage={h.img}
  structuredData={schema}
>
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 -z-10">
      <img src={h.img} alt={h.title} class="w-full h-full object-cover opacity-30" />
      <div class="absolute inset-0 bg-gradient-to-b from-ink/60 to-ink"></div>
    </div>
    <div class="max-w-7xl mx-auto px-5 md:px-8 py-20 md:py-28">
      <nav class="text-xs text-paper/60 mb-6">
        <a href="/" class="hover:text-amber">Home</a>
        <span class="mx-2">/</span>
        <a href="/shop" class="hover:text-amber">Shop</a>
        <span class="mx-2">/</span>
        <span class="text-paper/80">{collection.title}</span>
      </nav>
      <h1 class="font-display text-5xl md:text-7xl">{h.title}</h1>
      <p class="mt-4 max-w-2xl text-paper/75 text-lg">{h.blurb}</p>
      <div class="mt-8 flex flex-wrap gap-2 text-xs">
        <a href="/shop" class="rounded-full border border-white/15 px-4 py-2 hover:border-amber hover:text-amber">All \u00b7 {products.length}</a>
        {collections.map((c) => (
          <a href={`/collections/${c.slug}`} class={`rounded-full px-4 py-2 ${c.slug===collection.slug?'bg-amber text-ink font-semibold':'border border-white/15 hover:border-amber hover:text-amber'}`}>{c.title}</a>
        ))}
      </div>
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-5 md:px-8 py-16">
    {items.length > 0 ? (
      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        {items.map((p) => <ProductCard product={p} />)}
      </div>
    ) : (
      <div class="rounded-2xl border border-white/10 bg-black/40 p-10 text-center">
        <p class="text-paper/70">This shelf is empty for a moment. <a href="/shop" class="text-amber hover:underline">See the full shop \u2192</a></p>
      </div>
    )}
  </section>
</Base>
