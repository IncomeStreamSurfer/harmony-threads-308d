---
import Base from "../layouts/Base.astro";
import ProductCard from "../components/ProductCard.astro";
import { products, collections } from "../data/products";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Shop \u2014 Harmony Threads",
    description: "Every product in the Harmony Threads catalogue \u2014 apparel, digital downloads, and fragrance.",
    url: new URL("/shop", Astro.site).toString(),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: Astro.site?.toString() },
      { "@type": "ListItem", position: 2, name: "Shop",  item: new URL("/shop", Astro.site).toString() },
    ],
  },
];
---
<Base
  title="Shop \u2014 Harmony Threads"
  description="Every product in the Harmony Threads catalogue \u2014 apparel, digital downloads, and fragrance. Free UK delivery over \u00a340."
  structuredData={schema}
>
  <section class="max-w-7xl mx-auto px-5 md:px-8 pt-16 pb-10">
    <nav class="text-xs text-paper/60 mb-6">
      <a href="/" class="hover:text-amber">Home</a>
      <span class="mx-2">/</span>
      <span class="text-paper/80">Shop</span>
    </nav>
    <h1 class="font-display text-5xl md:text-6xl">The shop</h1>
    <p class="mt-4 max-w-2xl text-paper/70">Three products, handpicked by us, kept in stock in small quantities. Hand-screened apparel, long-form digital releases, and a signature fragrance.</p>
    <div class="mt-8 flex flex-wrap gap-2 text-xs">
      <a href="/shop" class="rounded-full bg-amber text-ink px-4 py-2 font-semibold">All \u00b7 {products.length}</a>
      {collections.map((c) => (
        <a href={`/collections/${c.slug}`} class="rounded-full border border-white/15 px-4 py-2 hover:border-amber hover:text-amber">{c.title}</a>
      ))}
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-5 md:px-8 pb-24">
    <div class="grid md:grid-cols-3 gap-6 md:gap-8">
      {products.map((p) => <ProductCard product={p} />)}
    </div>
  </section>
</Base>
